model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	discourageImplicitMeasures
	sourceQueryCulture: en-US

annotation PBI_QueryOrder = ["DatabricksServerHostname","DatabricksHttpPath","CatalogName","artemis_supply_risk","delay_trend"]

annotation PBI_ProTooling = ["WebModelingEdit"]

ref table artemis_supply_risk
ref table delay_trend

ref role 'Artemis-3 Analyst'

