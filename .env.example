# Copy to .env (gitignored) and adjust as needed. No real secrets — local demo only.

# --- PostgreSQL (system of record) ---
POSTGRES_USER=artemis
POSTGRES_PASSWORD=artemis_local_demo
POSTGRES_DB=procurement
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Data API Builder ---
DAB_CONNECTION_STRING=Host=postgres;Port=5432;Database=procurement;Username=artemis;Password=artemis_local_demo
DAB_PORT=5000

# --- Identity (local OIDC/JWT issuer; stands in for Microsoft Entra ID) ---
ISSUER_PORT=8081
JWT_ISSUER=https://issuer.local
JWT_AUDIENCE=artemis-api
# RS256 keys are generated by the issuer on first run; do not commit real keys.

# --- Kong gateway ---
KONG_PROXY_PORT=8000
KONG_ADMIN_PORT=8001
KONG_MANAGER_PORT=8002
RATE_LIMIT_PER_MINUTE=60

# --- Catalog service ---
CATALOG_PORT=8080

# --- MCP server ---
MCP_PORT=8090

# --- Source registry / control-plane (onboarding wizard) ---
REGISTRY_PORT=8095

# --- Catalog UI (optional frontend profile) ---
FRONTEND_PORT=5173

# --- Observability ---
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin_local_demo

# --- Azure pricing helper (no auth; public API) ---
AZURE_PRICE_REGION=usgovvirginia

# --- Synthetic data ---
SYNTHETIC_SEED=42
