{"type": "excalidraw", "version": 2, "source": "diagram-compiler", "elements": [{"type": "text", "id": "title-main", "x": 580.0, "y": 0, "text": "NASA API-first \u00b7 zero-move \u00b7 multi-source data marketplace", "fontSize": 36, "fontFamily": 3, "strokeColor": "#e2e8f0", "textAlign": "center"}, {"type": "text", "id": "title-sub", "x": 580.0, "y": 50, "text": "Data stays in its source \u2014 every call is brokered, authenticated, rate-limited and metered by the gateway (local OSS analogue).", "fontSize": 16, "fontFamily": 3, "strokeColor": "#94a3b8", "textAlign": "center"}, {"type": "rectangle", "id": "registry", "x": 360, "y": 100, "width": 280, "height": 220, "backgroundColor": "#4c0519", "strokeColor": "#fb7185", "strokeWidth": 2, "roughness": 0, "roundness": {"type": 3}}, {"type": "rectangle", "id": "consumers", "x": 720, "y": 100, "width": 280, "height": 220, "backgroundColor": "#0c4a6e", "strokeColor": "#7dd3fc", "strokeWidth": 2, "roughness": 0, "roundness": {"type": 3}}, {"type": "rectangle", "id": "catalog", "x": 1440, "y": 100, "width": 280, "height": 220, "backgroundColor": "#052e16", "strokeColor": "#86efac", "strokeWidth": 2, "roughness": 0, "roundness": {"type": 3}}, {"type": "rectangle", "id": "identity", "x": 0, "y": 420, "width": 280, "height": 220, "backgroundColor": "#4c0519", "strokeColor": "#fb7185", "strokeWidth": 2, "roughness": 0, "roundness": {"type": 3}}, {"type": "rectangle", "id": "kong", "x": 720, "y": 420, "width": 280, "height": 220, "backgroundColor": "#431407", "strokeColor": "#fdba74", "strokeWidth": 2, "roughness": 0, "roundness": {"type": 3}}, {"type": "rectangle", "id": "dot", "x": 360, "y": 740, "width": 280, "height": 220, "backgroundColor": "#431407", "strokeColor": "#fdba74", "strokeWidth": 2, "roughness": 0, "roundness": {"type": 3}}, {"type": "rectangle", "id": "dab", "x": 1080, "y": 740, "width": 280, "height": 220, "backgroundColor": "#0c4a6e", "strokeColor": "#7dd3fc", "strokeWidth": 2, "roughness": 0, "roundness": {"type": 3}}, {"type": "rectangle", "id": "prometheus", "x": 1440, "y": 740, "width": 280, "height": 220, "backgroundColor": "#0c4a6e", "strokeColor": "#7dd3fc", "strokeWidth": 2, "roughness": 0, "roundness": {"type": 3}}, {"type": "ellipse", "id": "postgres", "x": 1080, "y": 1060, "width": 280, "height": 220, "backgroundColor": "#052e16", "strokeColor": "#86efac", "strokeWidth": 2, "roughness": 0}, {"type": "text", "id": "registry-title", "x": 380, "y": 190, "width": 240, "height": 28, "text": "Registry", "fontSize": 18, "fontFamily": 3, "strokeColor": "#e2e8f0", "textAlign": "center"}, {"type": "text", "id": "registry-desc", "x": 380, "y": 222, "width": 240, "height": 78, "text": "Control-plane\nonboarding wizard", "fontSize": 14, "fontFamily": 3, "strokeColor": "#cbd5e1", "textAlign": "center"}, {"type": "text", "id": "consumers-title", "x": 740, "y": 190, "width": 240, "height": 28, "text": "Consumers", "fontSize": 18, "fontFamily": 3, "strokeColor": "#e2e8f0", "textAlign": "center"}, {"type": "text", "id": "consumers-desc", "x": 740, "y": 222, "width": 240, "height": 78, "text": "Python CLI \u00b7 MCP agent\nNASA-themed UI", "fontSize": 14, "fontFamily": 3, "strokeColor": "#cbd5e1", "textAlign": "center"}, {"type": "text", "id": "catalog-title", "x": 1460, "y": 190, "width": 240, "height": 28, "text": "Catalog", "fontSize": 18, "fontFamily": 3, "strokeColor": "#e2e8f0", "textAlign": "center"}, {"type": "text", "id": "catalog-desc", "x": 1460, "y": 222, "width": 240, "height": 78, "text": "Products \u00b7 owner\nclassification", "fontSize": 14, "fontFamily": 3, "strokeColor": "#cbd5e1", "textAlign": "center"}, {"type": "text", "id": "identity-title", "x": 20, "y": 510, "width": 240, "height": 28, "text": "Identity issuer", "fontSize": 18, "fontFamily": 3, "strokeColor": "#e2e8f0", "textAlign": "center"}, {"type": "text", "id": "identity-desc", "x": 20, "y": 542, "width": 240, "height": 78, "text": "RS256 JWT + JWKS", "fontSize": 14, "fontFamily": 3, "strokeColor": "#cbd5e1", "textAlign": "center"}, {"type": "text", "id": "kong-title", "x": 740, "y": 510, "width": 240, "height": 28, "text": "Kong Gateway (OSS)", "fontSize": 18, "fontFamily": 3, "strokeColor": "#e2e8f0", "textAlign": "center"}, {"type": "text", "id": "kong-desc", "x": 740, "y": 542, "width": 240, "height": 78, "text": "JWT \u00b7 rate-limit \u00b7 meter\ncorrelation-id \u00b7 OWASP", "fontSize": 14, "fontFamily": 3, "strokeColor": "#cbd5e1", "textAlign": "center"}, {"type": "text", "id": "dot-title", "x": 380, "y": 830, "width": 240, "height": 28, "text": "DOT Transportation API", "fontSize": 18, "fontFamily": 3, "strokeColor": "#e2e8f0", "textAlign": "center"}, {"type": "text", "id": "dot-desc", "x": 380, "y": 862, "width": 240, "height": 78, "text": "2nd source\nadded via wizard", "fontSize": 14, "fontFamily": 3, "strokeColor": "#cbd5e1", "textAlign": "center"}, {"type": "text", "id": "dab-title", "x": 1100, "y": 830, "width": 240, "height": 28, "text": "Data API Builder", "fontSize": 18, "fontFamily": 3, "strokeColor": "#e2e8f0", "textAlign": "center"}, {"type": "text", "id": "dab-desc", "x": 1100, "y": 862, "width": 240, "height": 78, "text": "auto REST \u00b7 GraphQL\nOpenAPI", "fontSize": 14, "fontFamily": 3, "strokeColor": "#cbd5e1", "textAlign": "center"}, {"type": "text", "id": "prometheus-title", "x": 1460, "y": 830, "width": 240, "height": 28, "text": "Prometheus + Grafana", "fontSize": 18, "fontFamily": 3, "strokeColor": "#e2e8f0", "textAlign": "center"}, {"type": "text", "id": "prometheus-desc", "x": 1460, "y": 862, "width": 240, "height": 78, "text": "per-consumer metrics", "fontSize": 14, "fontFamily": 3, "strokeColor": "#cbd5e1", "textAlign": "center"}, {"type": "text", "id": "postgres-title", "x": 1100, "y": 1150, "width": 240, "height": 28, "text": "PostgreSQL 16", "fontSize": 18, "fontFamily": 3, "strokeColor": "#e2e8f0", "textAlign": "center"}, {"type": "text", "id": "postgres-desc", "x": 1100, "y": 1182, "width": 240, "height": 78, "text": "Artemis SAP procurement\n(system of record)", "fontSize": 14, "fontFamily": 3, "strokeColor": "#cbd5e1", "textAlign": "center"}, {"type": "arrow", "id": "arrow-0", "start": {"id": "consumers", "focus": 0}, "end": {"id": "kong", "focus": 0.6}, "endArrowhead": "arrow", "strokeColor": "#fdba74", "strokeWidth": 2, "roughness": 0, "elbowed": true, "label": {"text": "bearer token \u00b7 REST", "fontSize": 13, "fontFamily": 3}}, {"type": "arrow", "id": "arrow-1", "start": {"id": "identity", "focus": 0}, "end": {"id": "kong", "focus": -0.6}, "endArrowhead": "arrow", "strokeColor": "#fb7185", "strokeWidth": 2, "roughness": 0, "elbowed": true, "label": {"text": "JWKS \u00b7 RS256", "fontSize": 13, "fontFamily": 3}, "strokeStyle": "dashed"}, {"type": "arrow", "id": "arrow-2", "start": {"id": "registry", "focus": 0}, "end": {"id": "kong", "focus": 0.0}, "endArrowhead": "arrow", "strokeColor": "#a78bfa", "strokeWidth": 2, "roughness": 0, "elbowed": true, "label": {"text": "hot-reload /config", "fontSize": 13, "fontFamily": 3}, "strokeStyle": "dashed"}, {"type": "arrow", "id": "arrow-3", "start": {"id": "kong", "focus": -0.2}, "end": {"id": "dab", "focus": 0}, "endArrowhead": "arrow", "strokeColor": "#7dd3fc", "strokeWidth": 2, "roughness": 0, "elbowed": true, "label": {"text": "REST / OData", "fontSize": 13, "fontFamily": 3}}, {"type": "arrow", "id": "arrow-4", "start": {"id": "kong", "focus": -0.6}, "end": {"id": "dot", "focus": 0}, "endArrowhead": "arrow", "strokeColor": "#fdba74", "strokeWidth": 2, "roughness": 0, "elbowed": true, "label": {"text": "federated route", "fontSize": 13, "fontFamily": 3}}, {"type": "arrow", "id": "arrow-5", "start": {"id": "dab", "focus": 0}, "end": {"id": "postgres", "focus": 0}, "endArrowhead": "arrow", "strokeColor": "#86efac", "strokeWidth": 2, "roughness": 0, "elbowed": true, "label": {"text": "SQL (stays put)", "fontSize": 13, "fontFamily": 3}}, {"type": "arrow", "id": "arrow-6", "start": {"id": "kong", "focus": 0.19999999999999996}, "end": {"id": "catalog", "focus": 0}, "endArrowhead": "arrow", "strokeColor": "#86efac", "strokeWidth": 2, "roughness": 0, "elbowed": true, "label": {"text": "publishes contract", "fontSize": 13, "fontFamily": 3}}, {"type": "arrow", "id": "arrow-7", "start": {"id": "kong", "focus": 0.6}, "end": {"id": "prometheus", "focus": 0}, "endArrowhead": "arrow", "strokeColor": "#7dd3fc", "strokeWidth": 2, "roughness": 0, "elbowed": true, "x": 1005, "y": 596.0, "points": [[0, 0.0], [380, 0.0], [380, 254.0], [430, 254.0]], "label": {"text": "scrape /metrics", "fontSize": 13, "fontFamily": 3}}, {"type": "rectangle", "id": "note-37", "x": 1440, "y": 1060, "width": 320, "height": 260, "backgroundColor": "#fef3c7", "strokeColor": "#f59e0b", "strokeWidth": 2, "roughness": 0, "roundness": {"type": 3}}, {"type": "text", "id": "note-37-header", "x": 1460, "y": 1080, "width": 280, "height": 30, "text": "Zero-move", "fontSize": 18, "fontFamily": 3, "textAlign": "center", "verticalAlign": "top", "strokeColor": "#451a03"}, {"type": "text", "id": "note-37-body", "x": 1464, "y": 1124, "width": 272, "height": 176, "text": "Postgres + DAB sit on an\ninternal Docker network with\nno host ports. The only path\nto data is through Kong.", "fontSize": 15, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#451a03"}, {"type": "rectangle", "id": "note-40", "x": -40, "y": 740, "width": 320, "height": 260, "backgroundColor": "#fef3c7", "strokeColor": "#f59e0b", "strokeWidth": 2, "roughness": 0, "roundness": {"type": 3}}, {"type": "text", "id": "note-40-header", "x": -20, "y": 760, "width": 280, "height": 30, "text": "Federation", "fontSize": 18, "fontFamily": 3, "textAlign": "center", "verticalAlign": "top", "strokeColor": "#451a03"}, {"type": "text", "id": "note-40-body", "x": -16, "y": 804, "width": 272, "height": 176, "text": "DOT is a 2nd source added\nlive via the registry\ncontrol-plane \u2014 no restart.", "fontSize": 15, "fontFamily": 3, "textAlign": "left", "verticalAlign